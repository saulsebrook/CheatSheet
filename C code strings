## COMMON GOTCHAS

// sizeof vs strlen — sizeof includes ‘\0’, strlen doesn’t
char s[] = “Hi”;
sizeof(s)   // → 3  (H i \0)
strlen(s)   // → 2

// sizeof on a pointer gives pointer size, NOT string length!
char *p = “Hi”;
sizeof(p)   // → 4 or 8 (pointer size!) ❌
strlen(p)   // → 2                       ✓

// Always leave room for ‘\0’
char buf[5];
strncpy(buf, src, 4);   // max 4 chars
buf[4] = ‘\0’;           // force terminate

// Cast to unsigned char for toupper/tolower (avoids UB)
toupper((unsigned char)c);   // ✓ correct

// strtok is NOT reentrant — use strtok_r for threads
char *save;
strtok_r(buf, “,”, &save);


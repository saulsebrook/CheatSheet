HAL_ADC_PollForConversion(&hadc1, 100);
uint32_t adcValue = HAL_ADC_GetValue(&hadc1);
HAL_ADC_Stop(&hadc1);

// Convert to voltage (3.3V ref, 12-bit)
float voltage = (adcValue / 4095.0) * 3.3;


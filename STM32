Bitwise Operations
uint8_t status = 0b10110100;

status & 0b00001111;  // AND - mask bits
status | 0b00000001;  // OR - set bits
status ^ 0b11111111;  // XOR - flip bits
~status;              // NOT - invert all bits
status << 2;          // Left shift
status >> 2;          // Right shift

// Common patterns
status |= (1 << 3);   // Set bit 3
status &= ~(1 << 3);  // Clear bit 3
status ^= (1 << 3);   // Toggle bit 3
if (status & (1 << 3)) { /* check if bit 3 is set */ }



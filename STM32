UART Functions
Init
UART_HandleTypeDef huart1;
huart1.Instance = USART1;
huart1.Init.BaudRate = 115200;
huart1.Init.WordLength = UART_WORDLENGTH_8B;
huart1.Init.StopBits = UART_STOPBITS_1;
huart1.Init.Parity = UART_PARITY_NONE;
huart1.Init.Mode = UART_MODE_TX_RX;
HAL_UART_Init(&huart1);

Transmit/Receive
// Send
uint8_t data[] = "Hello";
HAL_UART_Transmit(&huart1, data, sizeof(data), 1000);

// Receive (blocking)
uint8_t rxBuffer[100];
HAL_UART_Receive(&huart1, rxBuffer, 10, 5000);

// Receive with interrupt
HAL_UART_Receive_IT(&huart1, rxBuffer, 10);
void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart) {
    // Data received
}

I2C Functions
Init
I2C_HandleTypeDef hi2c1;
hi2c1.Instance = I2C1;
hi2c1.Init.ClockSpeed = 100000;  // 100kHz standard, 400000 fast
hi2c1.Init.AddressingMode = I2C_ADDRESSINGMODE_7BIT;
HAL_I2C_Init(&hi2c1);

Master Transmit/Receive
uint16_t devAddr = 0x76 << 1;  // Device address shifted

// Send data
uint8_t txData[] = {0x01, 0x02};
HAL_I2C_Master_Transmit(&hi2c1, devAddr, txData, 2, 1000);

// Receive data
uint8_t rxData[10];
HAL_I2C_Master_Receive(&hi2c1, devAddr, rxData, 10, 1000);

// Check if device present
if (HAL_I2C_IsDeviceReady(&hi2c1, devAddr, 3, 1000) == HAL_OK) {
    // Device found
}

Memory Operations (Registers)
// Write to register
uint16_t regAddr = 0xF4;
uint8_t data = 0x27;
HAL_I2C_Mem_Write(&hi2c1, devAddr, regAddr, 1, &data, 1, 1000);

// Read from register
uint8_t regValue;
HAL_I2C_Mem_Read(&hi2c1, devAddr, regAddr, 1, &regValue, 1, 1000);

// Read multiple bytes
uint8_t tempData[3];
HAL_I2C_Mem_Read(&hi2c1, devAddr, 0xFA, 1, tempData, 3, 1000);

SPI Functions
Init
SPI_HandleTypeDef hspi1;
hspi1.Instance = SPI1;
hspi1.Init.Mode = SPI_MODE_MASTER;
hspi1.Init.Direction = SPI_DIRECTION_2LINES;
hspi1.Init.DataSize = SPI_DATASIZE_8BIT;
hspi1.Init.CLKPolarity = SPI_POLARITY_LOW;
hspi1.Init.CLKPhase = SPI_PHASE_1EDGE;
hspi1.Init.NSS = SPI_NSS_SOFT;
hspi1.Init.FirstBit = SPI_FIRSTBIT_MSB;
HAL_SPI_Init(&hspi1);

Transmit/Receive
// Transmit
HAL_GPIO_WritePin(GPIOA, GPIO_PIN_4, GPIO_PIN_RESET);  // CS low
HAL_SPI_Transmit(&hspi1, txData, 3, 1000);
HAL_GPIO_WritePin(GPIOA, GPIO_PIN_4, GPIO_PIN_SET);    // CS high

// Receive
HAL_GPIO_WritePin(GPIOA, GPIO_PIN_4, GPIO_PIN_RESET);
HAL_SPI_Receive(&hspi1, rxData, 10, 1000);
HAL_GPIO_WritePin(GPIOA, GPIO_PIN_4, GPIO_PIN_SET);

// Transmit and receive simultaneously
HAL_GPIO_WritePin(GPIOA, GPIO_PIN_4, GPIO_PIN_RESET);
HAL_SPI_TransmitReceive(&hspi1, txBuf, rxBuf, 3, 1000);
HAL_GPIO_WritePin(GPIOA, GPIO_PIN_4, GPIO_PIN_SET);

ADC Functions
Init & Configure

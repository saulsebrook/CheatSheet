# HAL Quick Reference Guide

## GPIO Functions

### Pin Configuration
```cpp
GPIO_InitTypeDef GPIO_InitStruct = {0};
GPIO_InitStruct.Pin = GPIO_PIN_5;
GPIO_InitStruct.Mode = GPIO_MODE_OUTPUT_PP;  // or INPUT, OUTPUT_OD, AF_PP, ANALOG
GPIO_InitStruct.Pull = GPIO_NOPULL;          // or PULLUP, PULLDOWN
GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_LOW;
HAL_GPIO_Init(GPIOA, &GPIO_InitStruct);

// INPUT MODES
GPIO_MODE_INPUT              // Digital input, high impedance
// Example: Reading a button, switch, or digital sensor
GPIO_InitStruct.Mode = GPIO_MODE_INPUT;
GPIO_InitStruct.Pull = GPIO_PULLUP;  // Use pullup for buttons

GPIO_MODE_ANALOG             // Analog input for ADC
// Example: Reading temperature sensor, potentiometer
GPIO_InitStruct.Mode = GPIO_MODE_ANALOG;
GPIO_InitStruct.Pull = GPIO_NOPULL;  // No pull resistors in analog mode

// OUTPUT MODES
GPIO_MODE_OUTPUT_PP          // Push-pull output (can source and sink current)
// Example: Driving LEDs, controlling relays, most general outputs
// Can output both HIGH (3.3V) and LOW (0V) strongly
GPIO_InitStruct.Mode = GPIO_MODE_OUTPUT_PP;
GPIO_InitStruct.Pull = GPIO_NOPULL;
GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_LOW;

GPIO_MODE_OUTPUT_OD          // Open-drain output (can only sink current)
// Example: I2C communication, interfacing with 5V devices
// Can only pull LOW, needs external pullup for HIGH
// Used when multiple devices share a line (wired-AND)
GPIO_InitStruct.Mode = GPIO_MODE_OUTPUT_OD;
GPIO_InitStruct.Pull = GPIO_PULLUP;  // Usually needs pullup
GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_MEDIUM;

// ALTERNATE FUNCTION MODES
GPIO_MODE_AF_PP              // Alternate function push-pull
// Example: UART TX, SPI MOSI/MISO/SCK, PWM output
// Pin controlled by peripheral (UART, SPI, TIM, etc.)
GPIO_InitStruct.Mode = GPIO_MODE_AF_PP;
GPIO_InitStruct.Alternate = GPIO_AF7_USART1;  // Specify which function
GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_HIGH;

GPIO_MODE_AF_OD              // Alternate function open-drain
// Example: I2C SDA/SCL pins
// Peripheral controls pin in open-drain mode
GPIO_InitStruct.Mode = GPIO_MODE_AF_OD;
GPIO_InitStruct.Alternate = GPIO_AF4_I2C1;
GPIO_InitStruct.Pull = GPIO_PULLUP;
GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_HIGH;

// INTERRUPT MODES
GPIO_MODE_IT_RISING          // Interrupt on rising edge (LOW to HIGH)
// Example: Button press detection, pulse counting
GPIO_InitStruct.Mode = GPIO_MODE_IT_RISING;
GPIO_InitStruct.Pull = GPIO_PULLDOWN;  // Start LOW, trigger on HIGH

GPIO_MODE_IT_FALLING         // Interrupt on falling edge (HIGH to LOW)
// Example: Button release, timeout detection
GPIO_InitStruct.Mode = GPIO_MODE_IT_FALLING;
GPIO_InitStruct.Pull = GPIO_PULLUP;  // Start HIGH, trigger on LOW

GPIO_MODE_IT_RISING_FALLING  // Interrupt on both edges
// Example: Detecting any change, edge counting, frequency measurement
GPIO_InitStruct.Mode = GPIO_MODE_IT_RISING_FALLING;
GPIO_InitStruct.Pull = GPIO_NOPULL;

// EVENT MODES (similar to interrupt but doesn't invoke ISR)
GPIO_MODE_EVT_RISING         // Event on rising edge
GPIO_MODE_EVT_FALLING        // Event on falling edge
GPIO_MODE_EVT_RISING_FALLING // Event on both edges

GPIO_NOPULL                  // No pull-up or pull-down
// Example: When external pullup/pulldown exists, analog pins
// Pin floats when not driven - can pick up noise

GPIO_PULLUP                  // Enable internal pull-up (~40kΩ)
// Example: Buttons (active-low), I2C lines, open-drain outputs
// Pin reads HIGH when nothing connected
// When button pressed (connects to GND), pin reads LOW
GPIO_InitStruct.Pull = GPIO_PULLUP;

GPIO_PULLDOWN                // Enable internal pull-down (~40kΩ)
// Example: Buttons (active-high), ensuring known LOW state
// Pin reads LOW when nothing connected
// When button pressed (connects to VCC), pin reads HIGH
GPIO_InitStruct.Pull = GPIO_PULLDOWN;

GPIO_SPEED_FREQ_LOW          // Low speed (2 MHz typical)
// Example: LEDs, slow sensors, buttons
// Lower speed = lower EMI, lower power consumption

GPIO_SPEED_FREQ_MEDIUM       // Medium speed (25 MHz typical)
// Example: I2C, UART at moderate baud rates

GPIO_SPEED_FREQ_HIGH         // High speed (50 MHz typical)
// Example: SPI, fast UART, high-speed protocols

GPIO_SPEED_FREQ_VERY_HIGH    // Very high speed (100+ MHz typical)
// Example: High-speed SPI, memory interfaces, fast clocks
// Higher speed = faster edges, more EMI, more power

// LED Output (most common)
GPIO_InitStruct.Pin = GPIO_PIN_13;
GPIO_InitStruct.Mode = GPIO_MODE_OUTPUT_PP;
GPIO_InitStruct.Pull = GPIO_NOPULL;
GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_LOW;
HAL_GPIO_Init(GPIOC, &GPIO_InitStruct);

// Button Input (active-low with pullup)
GPIO_InitStruct.Pin = GPIO_PIN_0;
GPIO_InitStruct.Mode = GPIO_MODE_INPUT;
GPIO_InitStruct.Pull = GPIO_PULLUP;
HAL_GPIO_Init(GPIOA, &GPIO_InitStruct);

// Button with Interrupt (detect press)
GPIO_InitStruct.Pin = GPIO_PIN_0;
GPIO_InitStruct.Mode = GPIO_MODE_IT_FALLING;  // Trigger when pressed
GPIO_InitStruct.Pull = GPIO_PULLUP;
HAL_GPIO_Init(GPIOA, &GPIO_InitStruct);
HAL_NVIC_EnableIRQ(EXTI0_IRQn);  // Enable interrupt

// UART TX Pin (alternate function)
GPIO_InitStruct.Pin = GPIO_PIN_9;
GPIO_InitStruct.Mode = GPIO_MODE_AF_PP;
GPIO_InitStruct.Pull = GPIO_NOPULL;
GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_HIGH;
GPIO_InitStruct.Alternate = GPIO_AF7_USART1;
HAL_GPIO_Init(GPIOA, &GPIO_InitStruct);

// I2C SDA Pin (alternate function, open-drain)
GPIO_InitStruct.Pin = GPIO_PIN_7;
GPIO_InitStruct.Mode = GPIO_MODE_AF_OD;
GPIO_InitStruct.Pull = GPIO_PULLUP;  // I2C requires pullups
GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_HIGH;
GPIO_InitStruct.Alternate = GPIO_AF4_I2C1;
HAL_GPIO_Init(GPIOB, &GPIO_InitStruct);

// ADC Input (analog mode)
GPIO_InitStruct.Pin = GPIO_PIN_0;
GPIO_InitStruct.Mode = GPIO_MODE_ANALOG;
GPIO_InitStruct.Pull = GPIO_NOPULL;
HAL_GPIO_Init(GPIOA, &GPIO_InitStruct);

// Open-Drain Output (for level shifting to 5V)
GPIO_InitStruct.Pin = GPIO_PIN_8;
GPIO_InitStruct.Mode = GPIO_MODE_OUTPUT_OD;
GPIO_InitStruct.Pull = GPIO_PULLUP;  // Or external 10kΩ to 5V
GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_LOW;
HAL_GPIO_Init(GPIOA, &GPIO_InitStruct);

// PWM Output (timer alternate function)
GPIO_InitStruct.Pin = GPIO_PIN_6;
GPIO_InitStruct.Mode = GPIO_MODE_AF_PP;
GPIO_InitStruct.Pull = GPIO_NOPULL;
GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_HIGH;
GPIO_InitStruct.Alternate = GPIO_AF2_TIM3;
HAL_GPIO_Init(GPIOA, &GPIO_InitStruct);




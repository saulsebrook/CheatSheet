## COMMON GOTCHAS

// Integer division truncates — cast first!
int a = 7, b = 2;
float r = a / b;         // ❌ → 3.0 (int division)
float r = (float)a / b;  // ✓ → 3.5

// Mixing signed and unsigned compares — unsigned wins!
int      i = -1;
uint32_t u = 0;
if (i < u) { }   // ❌ false! -1 converts to huge uint

// Float equality — never use ==
if (f == 3.14f) { }                   // ❌ unreliable
if (fabs(f - 3.14f) < 1e-6f) { }     // ✓ epsilon compare

// Shift amount must be < bit width
uint32_t x = 1U << 32;   // ❌ undefined behaviour
uint64_t x = 1ULL << 32; // ✓ use wider type

// % on negatives is implementation-defined before C99
// In C99+ it truncates toward zero:
-7 % 3  → -1   // not 2

// Forgetting to use %lf for double in scanf
double d;
scanf(”%f”,  &d);   // ❌ reads as float, corrupts d
scanf(”%lf”, &d);   // ✓


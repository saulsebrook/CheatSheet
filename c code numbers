## PRINTING NUMBERS

printf(”%d\n”,   i);          // signed decimal
printf(”%u\n”,   u);          // unsigned decimal
printf(”%ld\n”,  l);          // long
printf(”%lld\n”, ll);         // long long
printf(”%f\n”,   f);          // float/double
printf(”%.2f\n”, f);          // 2 decimal places
printf(”%e\n”,   f);          // scientific: 3.140000e+00
printf(”%g\n”,   f);          // shorter of %f or %e

// Hex
printf(”%x\n”,   i);          // hex lowercase: ff
printf(”%X\n”,   i);          // hex uppercase: FF
printf(“0x%X\n”, i);          // with prefix:   0xFF
printf(”%08X\n”, i);          // zero-padded 8 wide: 000000FF
printf(”%02X\n”, byte);       // byte as 2 hex digits: 0A

// Fixed-width types need special macros from <inttypes.h>
#include <inttypes.h>
printf(”%” PRIu32 “\n”, u32); // correct for uint32_t
printf(”%” PRId64 “\n”, i64); // correct for int64_t
printf(”%” PRIx32 “\n”, u32); // hex for uint32_t

// Print raw bytes as hex (e.g. dump a buffer)
for (int i = 0; i < len; i++)
printf(”%02X “, buf[i]);
printf(”\n”);


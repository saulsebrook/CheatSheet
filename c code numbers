## BITWISE OPERATIONS

a & b       // AND
a | b       // OR
a ^ b       // XOR
~a          // NOT (bitwise complement)
a << n      // left shift  (multiply by 2^n)
a >> n      // right shift (divide by 2^n, logical for unsigned)

// Common patterns
x |=  (1U << 3);   // SET   bit 3
x &= ~(1U << 3);   // CLEAR bit 3
x ^=  (1U << 3);   // TOGGLE bit 3
(x >> 3) & 1       // READ  bit 3 (0 or 1)

// Extract a byte from a word
uint8_t  lo = (val)       & 0xFF;  // low byte
uint8_t  hi = (val >> 8)  & 0xFF;  // high byte
uint8_t  b2 = (val >> 16) & 0xFF;  // byte 2
uint8_t  b3 = (val >> 24) & 0xFF;  // byte 3

// Pack two bytes into a uint16
uint16_t word = ((uint16_t)hi << 8) | lo;

// Pack four bytes into a uint32
uint32_t w = ((uint32_t)b3 << 24) | ((uint32_t)b2 << 16)
| ((uint32_t)hi << 8)  |  (uint32_t)lo;

// Check if value is power of 2
(n > 0) && ((n & (n - 1)) == 0)

// Round up to next multiple of 4
(n + 3) & ~3


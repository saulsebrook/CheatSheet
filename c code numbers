## SCANNING / PARSING NUMBERS

// From stdin
scanf(”%d”,  &i);
scanf(”%u”,  &u);
scanf(”%f”,  &f);
scanf(”%lf”, &d);             // double needs %lf with scanf!
scanf(”%x”,  &i);             // parse hex input

// From a string
sscanf(buf, “%d %f”, &i, &f);
sscanf(buf, “0x%X”,  &hex_val);

// strtol — safest integer parse (base 10)
char *end;
long v = strtol(str, &end, 10);
if (*end != ‘\0’) { /* parse error */ }

// strtoul — unsigned
unsigned long u = strtoul(str, &end, 10);

// strtol for hex (base 16)
long h = strtol(“0xFF”, NULL, 16);  // → 255
long h = strtol(“FF”,   NULL, 16);  // → 255 (no prefix needed)

// strtod — double from string
double d = strtod(“3.14159”, NULL);

// Quick and dirty (no error checking)
int   i = atoi(“42”);
float f = atof(“3.14”);
long  l = atol(“100000”);


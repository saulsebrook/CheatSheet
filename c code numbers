## OVERFLOW & WRAPPING

// Unsigned wraps on overflow (defined behaviour)
uint8_t x = 255; x++;   // → 0

// Signed overflow is UNDEFINED BEHAVIOUR — avoid it!
int8_t  y = 127; y++;   // ❌ undefined

// Safe add with overflow check
if (a > UINT32_MAX - b) { /* overflow! */ }

// GCC built-in overflow detection
if (__builtin_add_overflow(a, b, &result)) { /* overflow */ }
if (__builtin_mul_overflow(a, b, &result)) { /* overflow */ }


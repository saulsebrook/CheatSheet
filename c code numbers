## TYPE CASTING

(int)f             // float to int — truncates toward zero
(float)i           // int to float
(uint8_t)i         // truncate to byte (wraps on overflow)
(uint32_t)(int32_t)i  // sign-extend then zero-extend

// Safe widening (always ok)
uint8_t  b = 200;
uint16_t w = b;    // implicit, fine

// Narrowing — be explicit and aware of truncation
uint32_t big = 0x1234;
uint8_t  lo  = (uint8_t)big;   // → 0x34

